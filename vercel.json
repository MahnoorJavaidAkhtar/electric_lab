{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@latest",
      "includeFiles": "{vendor/**,public/**,storage/**,bootstrap/**,config/**,database/**,resources/**,routes/**,app/**,artisan,.env}"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "outputDirectory": "public"
}